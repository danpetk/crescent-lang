func test(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64) : i64 {
    return a + b + c + d + e + f + g;
}

func is_prime(n : i64) : i64 {
    if n < 2 {
        return 0;
    }

    let i: i64 = 2;
    while i * i <= n {
        if n - (n / i) * i == 0 {
            return 0;
        }
        i = i + 1;
    }
   
    return 1;
}

func main() : i64 {
    return test(1,2,3,4,5,6,7);
    // return is_prime(998244353);
}
