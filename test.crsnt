// IsPrime
func main() : i64 {

    // Number to check 
    let n: i64 = 999999937;

    if n < 2 {
        return 0;
    }
    let i: i64 = 2;
    while i * i <= n {
        if n - (n / i) * i == 0 {
            return 0;
        }
        i = i + 1;
    }
   

    return 1;
}
